---
import Layout from '../layouts/default.astro';
import Series from '../components/home/series.astro';
import Partners from '../components/home/partners.astro';
import Support from '../components/home/support.astro';
import Newsletter from '../components/home/newsletter.astro';
import PageHeader from '../components/page-header.astro';

const title = 'tv for developers — CodeTV';
const description =
	'Original series featuring real developers. Learn something new. Build with the latest tools. Grow your career, together with the best community in tech.';

export const prerender = true;
---

<Layout title={title} description={description}>
	<main>
		<PageHeader
			video={{
				public_id: 'xNO1algWfSRXfTW7UffcEkv5qELfRmPnpmXwKls493U',
				publish_date: '2026-02-07T00:00:00Z',
				title: 'CodeTV WDC S2 Reel',
			}}
			line1="tv for developers"
			line2="made by developers"
		/>

		<Series />

		<Partners />

		<Support />

		<Newsletter />
	</main>
</Layout>
